# Server
PORT=5000
NODE_ENV=development

# Database - set to 'sqlite' for zero-config, or 'postgres' for production
DB_DIALECT=sqlite

# PostgreSQL settings (only needed when DB_DIALECT=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=moci_inventory
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:3000
